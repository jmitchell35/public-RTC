{
  "productName": "RTC",
  "version": "0.1.0",
  "identifier": "com.rtc.desktop",
  "build": {
    "beforeDevCommand": "mkdir -p .next/standalone && npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build && cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/"
  },
  "app": {
    "windows": [
      {
        "title": "RTC",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../.next/standalone": "standalone"
    }
  },
  "plugins": {
    "notification": null
  }
}
